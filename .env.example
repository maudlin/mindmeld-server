# MindMeld Server environment variables
# Copy to .env and adjust values as needed

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
JSON_LIMIT=1mb
LOG_LEVEL=debug
# Dev rate limiting (optional overrides)
RATE_LIMIT_MAX=600
RATE_LIMIT_WINDOW_MS=60000

# As-Is storage (file)
STATE_FILE_PATH=./data/state.json

# Planned: /maps API with SQLite
SQLITE_FILE=./data/db.sqlite
FEATURE_MAPS_API=1
